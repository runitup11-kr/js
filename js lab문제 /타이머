<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <div id="app" style="text-align: center; padding: 50px;">
    <h1 id="timerDisplay" style="font-size: 80px;">30:00</h1>
    
    <div id="controls">
        <button onclick="timerApp.start()">시작</button>
        <button onclick="timerApp.stop()">정지</button>
        <button onclick="timerApp.reset()">리셋</button>
    </div>
</div>  
    <script>
        const timerApp = {
            timeLeft:1800,
            timerId: null,

            render(){
                const minutes = Math.floor(this.timeLeft / 60);
                const seconds = this.timeLeft % 60;

                const displaySeconds = seconds < 10 ? `0${seconds}` : seconds;

                document.getElementById('timerDisplay').textContent = `${minutes}:${displaySeconds}`;
            },
            start(){
                if(this.timerId) return;

                this.timerId = setInterval(()=>{
                    this.timeLeft --;
                    this.render();

                    if(this.timeLeft <= 0){
                        clearInterval(this.timerId);
                        this.timerId = null;
                        alert("종료!");
                    } 
                },1000);
            },
            stop(){
                clearInterval(this.timerId);
                this.timerId = null;
            },
            reset(){
                this.stop();
                this.timeLeft = 1800;
                this.render();
            }
        }
    </script>
</body>
</html>
